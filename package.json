{
  "name": "collab-docs",
  "version": "1.0.0",
  "description": "Real-time collaboration tool with React, Node.js, Express, Socket.IO, and Supabase",
  "private": true,
  "scripts": {
    "dev": "npm run client",
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "cd server && npm start",
    "setup": "npm install && cd server && npm install && cd ../client && npm install"
  },
  "keywords": [
    "collaboration",
    "real-time",
    "documents",
    "socket.io",
    "react",
    "supabase"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.1"
  }
}
